# ローカル開発時にコピーして .env.local にリネームして使う

# Socket.IO サーバーの URL
# デフォルト (本番): https://vibrade-server.onrender.com
# ローカル開発時の例: http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# QR コードが指すモバイルクライアントの URL
# デフォルト (本番): https://vibrade-mobile.vercel.app
# ローカル開発時の例: http://localhost:5174
VITE_MOBILE_URL=http://localhost:5174
